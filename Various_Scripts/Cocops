      `$sku = Get-MgSubscribedSku | Where-Object SkuPartNumber -eq 'ENTERPRISEPACK'
      `$users = Import-Csv '$LogPath' | Where-Object { `$_.Status -eq 'CREATED' -and `$_.Type -eq 'User' }
      foreach (`$u in `$users) {
          Set-MgUserLicense -UserId `$u.NewUPN ``
